# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- AI Providers ---
# Google Gemini (for audit chat & clarification)
GEMINI_API_KEY=your_gemini_api_key

# Groq (for floor-plan vision analysis — faster & cheaper than Gemini Vision)
# Get a key at https://console.groq.com (keys often start with gsk_)
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VITE_GROQ_BASE_URL=https://api.groq.com/openai/v1
